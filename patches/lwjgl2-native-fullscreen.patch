+- (NSApplicationPresentationOptions)window:(NSWindow *)window willUseFullScreenPresentationOptions:(NSApplicationPresentationOptions)proposedOptions {
+	// Replace auto-hide with hard-hide to prevent the fullscreen titlebar
+	// slide-down animation on mouse hover, which causes rendering stutter.
+	NSApplicationPresentationOptions opts = proposedOptions;
+	opts &= ~(NSApplicationPresentationAutoHideMenuBar | NSApplicationPresentationAutoHideDock);
+	opts |= NSApplicationPresentationHideMenuBar | NSApplicationPresentationHideDock;
+	return opts;
+}
+
+- (void)windowDidEnterFullScreen:(NSNotification *)notification {
+	if (_parent != nil) {
+		int width = _parent->display_rect.size.width;
+		int height = _parent->display_rect.size.height;
+		
+		NSOpenGLContext *ctx = [self openGLContext];
+		if (ctx != nil) {
+			CGLContextObj cgl = (CGLContextObj)[ctx CGLContextObj];
+			GLint dim[2] = {width, height};
+			CGLSetParameter(cgl, kCGLCPSurfaceBackingSize, dim);
+			CGLEnable(cgl, kCGLCESurfaceBackingSize);
+		}
+		
+		NSSize ws = [[self window] frame].size;
+		[self setBoundsSize:NSMakeSize(ws.width/(CGFloat)width*ws.width,
+		                               ws.height/(CGFloat)height*ws.height)];
+	}
+}
